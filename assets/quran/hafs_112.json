    "name": "al-Ikhlash",
    "verse": {
        "verse_0": "بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ",
        "verse_1": "قُلۡ هُوَ ٱللَّهُ أَحَدٌ",
        "verse_2": "ٱللَّهُ ٱلصَّمَدُ",
        "verse_3": "لَمۡ يَلِدۡ وَلَمۡ يُولَدۡ",
        "verse_4": "وَلَمۡ يَكُن لَّهُۥ كُفُوًا أَحَدُۢ"
