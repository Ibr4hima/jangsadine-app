{
    "index": "107",
    "name": "al-Ma'un",
    "verse": {
        "verse_0": "بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ",
        "verse_1": "أَرَءَيۡتَ ٱلَّذِي يُكَذِّبُ بِٱلدِّينِ",
        "verse_2": "فَذَٰلِكَ ٱلَّذِي يَدُعُّ ٱلۡيَتِيمَ",
        "verse_3": "وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلۡمِسۡكِينِ",
        "verse_4": "فَوَيۡلٞ لِّلۡمُصَلِّينَ",
        "verse_5": "ٱلَّذِينَ هُمۡ عَن صَلَاتِهِمۡ سَاهُونَ",
        "verse_6": "ٱلَّذِينَ هُمۡ يُرَآءُونَ",
        "verse_7": "وَيَمۡنَعُونَ ٱلۡمَاعُونَ"
    },
    "count": 7
}