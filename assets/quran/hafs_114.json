{
    "index": "114",
    "name": "an-Nas",
    "verse": {
        "verse_0": "بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ",
        "verse_1": "قُلۡ أَعُوذُ بِرَبِّ ٱلنَّاسِ",
        "verse_2": "مَلِكِ ٱلنَّاسِ",
        "verse_3": "إِلَٰهِ ٱلنَّاسِ",
        "verse_4": "مِن شَرِّ ٱلۡوَسۡوَاسِ ٱلۡخَنَّاسِ",
        "verse_5": "ٱلَّذِي يُوَسۡوِسُ فِي صُدُورِ ٱلنَّاسِ",
        "verse_6": "مِنَ ٱلۡجِنَّةِ وَٱلنَّاسِ"
    },
    "count": 6
}