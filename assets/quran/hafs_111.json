{
    "index": "111",
    "name": "Al-Masad",
    "verse": {
        "verse_0": "بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ",
        "verse_1": "تَبَّتۡ يَدَآ أَبِي لَهَبٖ وَتَبَّ",
        "verse_2": "مَآ أَغۡنَىٰ عَنۡهُ مَالُهُۥ وَمَا كَسَبَ",
        "verse_3": "سَيَصۡلَىٰ نَارٗا ذَاتَ لَهَبٖ",
        "verse_4": "وَٱمۡرَأَتُهُۥ حَمَّالَةَ ٱلۡحَطَبِ",
        "verse_5": "فِي جِيدِهَا حَبۡلٞ مِّن مَّسَدِۭ"
    },
    "count": 5
}